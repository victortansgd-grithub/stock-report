# Gmail sender address (e.g. yourname@gmail.com)
GMAIL_SENDER=your_email@gmail.com

# Gmail App Password (NOT your regular Gmail password!)
# Steps to generate:
#   1. Enable 2-Step Verification: https://myaccount.google.com/security
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Select app = "Mail", device = "Other", name it "StockReport"
#   4. Copy the 16-character password and paste below (no spaces)
GMAIL_APP_PASSWORD=your_16char_app_password

# Recipient email address
RECIPIENT_EMAIL=victortansgd@gmail.com
